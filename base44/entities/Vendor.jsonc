{
  "name": "Vendor",
  "type": "object",
  "properties": {
    "company_name": {
      "type": "string",
      "description": "Supply house / vendor company name"
    },
    "contact_name": {
      "type": "string",
      "description": "Primary contact name"
    },
    "email": {
      "type": "string",
      "description": "Contact email"
    },
    "phone": {
      "type": "string",
      "description": "Contact phone"
    },
    "address": {
      "type": "string",
      "description": "Vendor address"
    },
    "category": {
      "type": "string",
      "enum": [
        "Lumber & Building Materials",
        "Electrical",
        "Plumbing",
        "HVAC",
        "Roofing",
        "Flooring",
        "Hardware",
        "Paint",
        "Concrete & Masonry",
        "General Supply",
        "Framing",
        "Plastering & Drywall",
        "Insulation",
        "Gutters",
        "Fencing",
        "Excavation & Foundation",
        "Finish Carpentry",
        "Cabinetry",
        "Decks & Porches",
        "Siding",
        "Sheet Metal",
        "Glass & Shower",
        "Landscaping",
        "Equipment Rental",
        "General Contracting",
        "Other"
      ],
      "description": "Vendor category / primary trade"
    },
    "notes": {
      "type": "string"
    },
    "active": {
      "type": "boolean",
      "default": true
    },
    "is_subcontractor": {
      "type": "boolean",
      "default": false,
      "description": "Whether this vendor is also a subcontractor requiring onboarding docs"
    },
    "packet_status": {
      "type": "string",
      "enum": [
        "not_started",
        "in_progress",
        "completed",
        "approved"
      ],
      "default": "not_started",
      "description": "Subcontractor onboarding packet completion status"
    },
    "packet_approved_by": {
      "type": "string",
      "description": "Admin email who approved the submitted packet"
    },
    "packet_approved_at": {
      "type": "string",
      "description": "ISO datetime when the packet was approved"
    },
    "packet_signed_name": {
      "type": "string",
      "description": "Name signed on the subcontractor packet"
    },
    "packet_signed_at": {
      "type": "string",
      "description": "ISO datetime when packet was signed"
    },
    "packet_signature_data": {
      "type": "string",
      "description": "Base64 signature image data URL"
    },
    "packet_form_data": {
      "type": "object",
      "description": "All form fields filled out in the packet"
    },
    "workers_comp_url": {
      "type": "string",
      "description": "Workers Compensation insurance certificate URL"
    },
    "workers_comp_expiry": {
      "type": "string",
      "format": "date",
      "description": "Workers Comp expiration date"
    },
    "liability_ins_url": {
      "type": "string",
      "description": "General Liability insurance certificate URL"
    },
    "liability_ins_expiry": {
      "type": "string",
      "format": "date",
      "description": "General Liability expiration date"
    },
    "w9_url": {
      "type": "string",
      "description": "W-9 form URL"
    },
    "insurance_status": {
      "type": "string",
      "enum": [
        "pending",
        "valid",
        "expiring_soon",
        "expired"
      ],
      "default": "pending",
      "description": "Combined insurance compliance status"
    },
    "insurance_expiry_notified_at": {
      "type": "string",
      "description": "Last time sub was notified about expiring/expired insurance (7\u201314d cadence)"
    },
    "insurance_30d_notified_at": {
      "type": "string",
      "description": "ISO datetime when the 30-day early expiry warning was last sent"
    },
    "missing_docs_notified_at": {
      "type": "string",
      "description": "Last time sub was notified about missing onboarding documents"
    },
    "missing_docs_notify_count": {
      "type": "integer",
      "default": 0,
      "description": "How many times the missing-docs sequence has fired \u2014 drives escalating cadence"
    },
    "compliance_sequence_paused": {
      "type": "boolean",
      "default": false,
      "description": "Admin can pause automated compliance emails for this sub"
    }
  },
  "required": [
    "company_name",
    "email"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "user_condition": {
        "role": "admin"
      }
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}