{
  "name": "Lead",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "description": "Contact's full name"
    },
    "email": {
      "type": "string",
      "description": "Contact's email address"
    },
    "phone": {
      "type": "string",
      "description": "Contact's phone number"
    },
    "phone_number": {
      "type": "string",
      "description": "Normalized phone number for SMS compliance lookup"
    },
    "sms_opt_in_status": {
      "type": "boolean",
      "default": false,
      "description": "Whether this lead opted in to SMS/MMS communications"
    },
    "sms_opt_in_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "sms_opt_in_method": {
      "type": "string",
      "enum": [
        "WEB_FORM",
        "VERBAL",
        "MANUAL"
      ],
      "default": "WEB_FORM"
    },
    "sms_consent_text_version": {
      "type": "string",
      "description": "Exact SMS consent text/version accepted by this lead"
    },
    "sms_opt_in_ip": {
      "type": "string",
      "description": "Client IP address at the moment the SMS consent decision was recorded (A2P compliance)"
    },
    "project_type": {
      "type": "string",
      "enum": [
        "Home Addition",
        "Kitchen Remodel",
        "Bathroom Remodel",
        "Deck / Porch / Pergola",
        "Siding",
        "Custom Carpentry",
        "Snow Removal",
        "Full Home Renovation",
        "Roofing",
        "General Inquiry"
      ],
      "description": "Type of project"
    },
    "message": {
      "type": "string",
      "description": "Message or project details from the lead"
    },
    "status": {
      "type": "string",
      "enum": [
        "New",
        "Contacted",
        "Won",
        "Lost"
      ],
      "default": "New",
      "description": "Current lead status"
    },
    "source": {
      "type": "string",
      "enum": [
        "Contact Form",
        "Design Preview",
        "Budget Estimator",
        "Phone",
        "Referral",
        "Angi",
        "Other"
      ],
      "description": "Where the lead came from"
    },
    "address": {
      "type": "string",
      "description": "Property address if provided"
    },
    "notes": {
      "type": "string",
      "description": "Internal admin notes"
    },
    "project_id": {
      "type": "string",
      "description": "Link to the associated Project record (Design Preview)"
    },
    "contractor_project_id": {
      "type": "string",
      "description": "Link to the associated ContractorProject record (auto-created for Angi leads)"
    },
    "angi_lead_id": {
      "type": "string",
      "description": "Angi's unique lead ID to prevent duplicates"
    },
    "angi_task": {
      "type": "string",
      "description": "Angi task/service category"
    },
    "angi_budget": {
      "type": "string",
      "description": "Customer's stated budget from Angi"
    },
    "angi_timeline": {
      "type": "string",
      "description": "Customer's stated timeline from Angi"
    },
    "angi_raw": {
      "type": "object",
      "description": "Full raw Angi lead payload for reference"
    },
    "booking_token": {
      "type": "string",
      "description": "Secure token for client self-scheduling a walkthrough"
    },
    "booking_event_id": {
      "type": "string",
      "description": "Google Calendar event id once the client books \u2014 idempotency marker"
    },
    "booking_sent_at": {
      "type": "string",
      "description": "ISO datetime when booking link was sent to the client"
    }
  },
  "required": [
    "full_name",
    "email",
    "phone"
  ],
  "rls": {
    "read": {
      "user_condition": {
        "role": "admin"
      }
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}