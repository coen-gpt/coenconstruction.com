{
  "name": "SyncState",
  "type": "object",
  "properties": {
    "key": {
      "type": "string",
      "description": "Unique identifier for this sync state, e.g. 'google_calendar'"
    },
    "sync_token": {
      "type": "string",
      "description": "Google Calendar incremental sync token"
    },
    "last_synced_at": {
      "type": "string",
      "description": "ISO datetime of last successful sync"
    }
  },
  "required": [
    "key"
  ]
}