{
  "name": "CompanyProfile",
  "type": "object",
  "properties": {
    "company_name": {
      "type": "string"
    },
    "logo_url": {
      "type": "string"
    },
    "brand_color": {
      "type": "string",
      "default": "#E35235"
    },
    "address": {
      "type": "string"
    },
    "city": {
      "type": "string"
    },
    "state": {
      "type": "string"
    },
    "zipcode": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "license_number": {
      "type": "string"
    },
    "default_markup_pct": {
      "type": "number",
      "default": 20
    },
    "default_tax_rate": {
      "type": "number",
      "default": 0
    },
    "profitability_threshold_pct": {
      "type": "number",
      "default": 15
    },
    "ai_system_instructions": {
      "type": "string"
    },
    "estimate_terms": {
      "type": "string"
    },
    "import_field_mapping": {
      "type": "object"
    },
    "pm_software_name": {
      "type": "string"
    },
    "mto_reply_email": {
      "type": "string",
      "description": "Reply-to email vendors use when responding to MTO requests \u2014 scanned for quotes",
      "default": "quotes@coenconstruction.com"
    },
    "sow_reply_email": {
      "type": "string",
      "description": "Reply-to email subs use when responding to SoW bid requests \u2014 scanned for quotes",
      "default": "bids@coenconstruction.com"
    },
    "lead_notification_email": {
      "type": "string",
      "description": "Email address that receives new lead notifications",
      "default": "scott@coenconstruction.com"
    },
    "phase_complete_notify_email": {
      "type": "string",
      "description": "Email address notified when a project phase is auto-completed (all sub-tasks done). Falls back to lead_notification_email if blank.",
      "default": ""
    },
    "google_place_id": {
      "type": "string",
      "description": "Google Business Profile Place ID used for live review fetching"
    },
    "enable_exit_intent_popup": {
      "type": "boolean",
      "default": true,
      "description": "Enable or disable the exit intent popup on the public website"
    },
    "contract_template_url": {
      "type": "string",
      "description": "URL of the uploaded client contract terms PDF template"
    },
    "contract_template_name": {
      "type": "string",
      "description": "Display name of the contract template file"
    },
    "deposit_percentage": {
      "type": "number",
      "default": 33,
      "description": "Default deposit percentage to collect upon estimate approval"
    },
    "booking_days": {
      "type": "array",
      "items": {
        "type": "integer"
      },
      "description": "Available days for walkthrough bookings. 0=Sun, 1=Mon, 2=Tue, 3=Wed, 4=Thu, 5=Fri, 6=Sat",
      "default": [
        1,
        2,
        3,
        4,
        5
      ]
    },
    "booking_start_hour": {
      "type": "integer",
      "description": "Earliest booking hour (24h, ET). e.g. 8 = 8am",
      "default": 8
    },
    "booking_end_hour": {
      "type": "integer",
      "description": "Latest booking start hour (24h, ET). e.g. 17 = 5pm (last slot at 5pm)",
      "default": 17
    },
    "booking_slot_minutes": {
      "type": "integer",
      "description": "Duration of each walkthrough slot in minutes",
      "default": 60
    },
    "booking_advance_days": {
      "type": "integer",
      "description": "Minimum days ahead a client can book (e.g. 1 = next day earliest)",
      "default": 1
    },
    "booking_window_days": {
      "type": "integer",
      "description": "How many days ahead to show availability (e.g. 14 = two weeks)",
      "default": 14
    }
  },
  "required": [
    "company_name"
  ]
}