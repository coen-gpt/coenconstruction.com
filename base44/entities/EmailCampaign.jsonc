{
  "name": "EmailCampaign",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Internal campaign name, e.g. 'June 2026 — Past Quotes Re-Engagement'"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "sending",
        "sent"
      ],
      "default": "draft",
      "description": "Lifecycle: draft (building audience) → sending (broadcast in progress) → sent"
    },
    "hero_image_url": {
      "type": "string",
      "description": "Hero image used at the top of every campaign email (defaults to the website home hero)"
    },
    "custom_note": {
      "type": "string",
      "description": "Optional personal note from the team appended to every email body"
    },
    "created_by": {
      "type": "string",
      "description": "Email of the admin who created the campaign"
    },
    "sent_at": {
      "type": "string",
      "description": "ISO datetime when the broadcast finished"
    },
    "wave_size": {
      "type": "number",
      "default": 200,
      "description": "Max emails per day — protects domain reputation by spreading the broadcast over days. 0 = unlimited (no daily cap)"
    },
    "drip_enabled": {
      "type": "boolean",
      "default": false,
      "description": "When true, the drip_tick action auto-sends sub-waves through the day until the daily wave_size is reached"
    },
    "drip_day": {
      "type": "string",
      "description": "UTC date (YYYY-MM-DD) the daily counter applies to — resets when the day rolls over"
    },
    "drip_sent_today": {
      "type": "number",
      "default": 0,
      "description": "Emails sent so far during drip_day (manual waves count too)"
    },
    "last_wave_at": {
      "type": "string",
      "description": "ISO datetime of the most recent wave/drip send"
    },
    "recipient_count": {
      "type": "number",
      "default": 0,
      "description": "Total recipients imported into the campaign"
    },
    "sent_count": {
      "type": "number",
      "default": 0,
      "description": "Emails successfully handed to Resend"
    },
    "failed_count": {
      "type": "number",
      "default": 0,
      "description": "Sends that failed (per-recipient failed_reason has details)"
    },
    "last_nudge_at": {
      "type": "string",
      "description": "ISO datetime of the most recent nudge pass"
    },
    "subject_a": {
      "type": "string",
      "description": "Optional pinned subject line (A variant). Supports {first_name} and {project} tokens. Blank = smart per-recipient subjects."
    },
    "subject_b": {
      "type": "string",
      "description": "Optional second subject line for A/B testing — recipients are split deterministically and campaign_stats reports per-variant opens/clicks"
    },
    "dedupe_window_days": {
      "type": "number",
      "default": 0,
      "description": "Cross-campaign dedupe look-back at import: skip anyone contacted within this many days (0 = all time)"
    },
    "allow_recontact": {
      "type": "boolean",
      "default": false,
      "description": "When true, the import skips the prior-campaign dedupe (unsubscribes, active clients, and open leads still suppress)"
    },
    "retarget_of": {
      "type": "string",
      "description": "Source EmailCampaign id when this draft was created by create_retarget_campaign (warm-audience clone)"
    }
  },
  "required": [
    "name"
  ],
  "rls": {
    "read": {
      "user_condition": {
        "role": "admin"
      }
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}
