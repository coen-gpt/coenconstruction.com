{
  "name": "SubBid",
  "type": "object",
  "properties": {
    "project_id": {
      "type": "string",
      "description": "Linked ContractorProject ID"
    },
    "vendor_id": {
      "type": "string",
      "description": "Linked Vendor ID"
    },
    "vendor_name": {
      "type": "string"
    },
    "vendor_email": {
      "type": "string"
    },
    "vendor_company": {
      "type": "string"
    },
    "trade": {
      "type": "string",
      "description": "Trade / scope being bid (e.g. Electrical, Framing)"
    },
    "invite_token": {
      "type": "string",
      "description": "Secure token for vendor portal access"
    },
    "invite_sent_at": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "invited",
        "viewed",
        "submitted",
        "selected",
        "rejected"
      ],
      "default": "invited"
    },
    "bid_amount": {
      "type": "number",
      "description": "Vendor's submitted bid amount"
    },
    "bid_notes": {
      "type": "string",
      "description": "Vendor's notes on the bid"
    },
    "quote_pdf_url": {
      "type": "string",
      "description": "Uploaded quote PDF URL"
    },
    "submitted_at": {
      "type": "string"
    },
    "selected_at": {
      "type": "string"
    },
    "internal_notes": {
      "type": "string",
      "description": "Admin notes on this bid"
    },
    "sow_id": {
      "type": "string",
      "description": "Linked SavedSoW ID (if bid was sent from a SoW)"
    },
    "sow_trade_items": {
      "type": "array",
      "description": "Snapshot of SoW line items for this trade, shown in the portal",
      "items": {
        "type": "object",
        "properties": {
          "item": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "quantity": {
            "type": "string"
          },
          "unit": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "source": {
      "type": "string",
      "enum": [
        "portal",
        "gmail_import",
        "drive_import",
        "manual"
      ],
      "description": "Where this bid came from; absent = legacy portal invite flow"
    },
    "gmail_message_id": {
      "type": "string",
      "description": "Gmail message the bid was imported from (dedupe key)"
    },
    "gmail_thread_id": {
      "type": "string"
    },
    "gmail_link": {
      "type": "string",
      "description": "Deep link to open the source email in Gmail"
    },
    "drive_file_id": {
      "type": "string",
      "description": "Google Drive file the bid was imported from"
    },
    "drive_link": {
      "type": "string",
      "description": "Deep link to view the source file in Google Drive"
    },
    "email_subject": {
      "type": "string"
    },
    "email_from": {
      "type": "string"
    },
    "email_received_date": {
      "type": "string"
    },
    "ai_summary": {
      "type": "string",
      "description": "1-2 sentence AI summary of the bid"
    },
    "ai_match_confidence": {
      "type": "number",
      "description": "0-100 confidence that this bid belongs to the linked project"
    },
    "ai_match_reason": {
      "type": "string",
      "description": "Why the AI matched this bid to the project"
    },
    "attachment_urls": {
      "type": "array",
      "description": "Base44-hosted copies of the quote documents",
      "items": {
        "type": "string"
      }
    },
    "attachment_names": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "vendor_phone": {
      "type": "string",
      "description": "Vendor contact phone extracted from the quote/email"
    },
    "payment_terms": {
      "type": "array",
      "description": "AI-extracted payment schedule from the quote (e.g. Deposit, Rough-In, Final)",
      "items": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string",
            "description": "e.g. Deposit, 2nd Payment, Final"
          },
          "amount": {
            "type": "number"
          },
          "percent": {
            "type": "number",
            "description": "Percent of contract if stated instead of a dollar amount"
          },
          "due_on": {
            "type": "string",
            "description": "Milestone or date the payment is due (as stated on the quote)"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  },
  "required": [
    "project_id",
    "vendor_email",
    "trade"
  ]
}