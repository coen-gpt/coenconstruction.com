{
  "name": "Estimate",
  "type": "object",
  "properties": {
    "project_id": {
      "type": "string",
      "description": "ContractorProject ID"
    },
    "version": {
      "type": "integer",
      "default": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "original",
        "change_order",
        "revision"
      ],
      "default": "original"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "sent",
        "approved",
        "rejected",
        "superseded"
      ],
      "default": "draft"
    },
    "title": {
      "type": "string",
      "default": "Estimate"
    },
    "line_items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "parent_group": {
            "type": "string"
          },
          "subgroup": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "unit": {
            "type": "string"
          },
          "unit_cost": {
            "type": "number"
          },
          "markup_pct": {
            "type": "number",
            "default": 0
          },
          "total": {
            "type": "number"
          },
          "cost_type": {
            "type": "string",
            "enum": [
              "labor",
              "material",
              "subcontractor",
              "allowance",
              "other"
            ]
          },
          "is_allowance": {
            "type": "boolean",
            "default": false
          },
          "actual_cost": {
            "type": "number"
          },
          "internal_notes": {
            "type": "string"
          }
        }
      }
    },
    "subtotal": {
      "type": "number",
      "default": 0
    },
    "tax_rate": {
      "type": "number",
      "default": 0
    },
    "tax_amount": {
      "type": "number",
      "default": 0
    },
    "grand_total": {
      "type": "number",
      "default": 0
    },
    "default_markup_pct": {
      "type": "number",
      "default": 20
    },
    "notes": {
      "type": "string"
    },
    "valid_until": {
      "type": "string",
      "format": "date"
    },
    "approved_date": {
      "type": "string",
      "format": "date"
    },
    "change_order_number": {
      "type": "integer"
    },
    "scope_change_description": {
      "type": "string"
    },
    "quickbooks_estimate_id": {
      "type": "string",
      "description": "QuickBooks Estimate Id (signed quote synced as a QBO Estimate)"
    },
    "quickbooks_invoice_id": {
      "type": "string",
      "description": "QuickBooks Invoice ID"
    },
    "quickbooks_invoice_number": {
      "type": "string",
      "description": "QuickBooks Invoice Number"
    },
    "quickbooks_synced_at": {
      "type": "string",
      "description": "ISO datetime when estimate was synced to QuickBooks"
    },
    "quickbooks_sync_status": {
      "type": "string",
      "enum": [
        "not_synced",
        "synced",
        "error",
        "pending"
      ],
      "default": "not_synced",
      "description": "QuickBooks sync status"
    }
  },
  "required": [
    "project_id"
  ]
}