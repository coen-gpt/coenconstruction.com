{
  "name": "ContractorProject",
  "type": "object",
  "properties": {
    "client_name": {
      "type": "string"
    },
    "client_phone": {
      "type": "string"
    },
    "client_email": {
      "type": "string"
    },
    "client_address": {
      "type": "string"
    },
    "client_city": {
      "type": "string"
    },
    "client_zipcode": {
      "type": "string"
    },
    "project_type": {
      "type": "string",
      "enum": [
        "Home Addition",
        "Kitchen Remodel",
        "Bathroom Remodel",
        "Deck / Porch / Pergola",
        "Siding",
        "Custom Carpentry",
        "Snow Removal",
        "Full Home Renovation",
        "Roofing",
        "Flooring",
        "Other"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "walkthrough",
        "draft",
        "pending_review",
        "approved",
        "denied",
        "modify",
        "in_progress",
        "completed",
        "cancelled",
        "imported"
      ],
      "default": "walkthrough"
    },
    "description": {
      "type": "string"
    },
    "scope_of_work": {
      "type": "string"
    },
    "rooms": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "dimensions": {
            "type": "string"
          }
        }
      }
    },
    "photos": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "URLs of uploaded site photos"
    },
    "photos_360": {
      "type": "array",
      "description": "360-degree equirectangular photos for virtual site walk with progress markers",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "description": "URL of 360\u00b0 equirectangular image"
          },
          "name": {
            "type": "string"
          },
          "thumbnail_url": {
            "type": "string",
            "description": "URL of thumbnail preview"
          },
          "uploaded_at": {
            "type": "string"
          },
          "markers": {
            "type": "array",
            "description": "Progress markers placed on this 360\u00b0 photo",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "pitch": {
                  "type": "number",
                  "description": "Vertical angle (-90 to 90)"
                },
                "yaw": {
                  "type": "number",
                  "description": "Horizontal angle (-180 to 180)"
                },
                "note": {
                  "type": "string",
                  "description": "Progress description for this marker"
                },
                "created_at": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "original_estimate_total": {
      "type": "number",
      "default": 0
    },
    "adjusted_total": {
      "type": "number",
      "default": 0
    },
    "client_signed": {
      "type": "boolean",
      "default": false
    },
    "signed_date": {
      "type": "string",
      "format": "date"
    },
    "contract_signed_pdf_url": {
      "type": "string",
      "description": "URL of the final signed contract PDF"
    },
    "contract_signature_data": {
      "type": "string",
      "description": "Client drawn e-signature data URL"
    },
    "contract_signed_at": {
      "type": "string",
      "description": "ISO datetime when contract was e-signed"
    },
    "deposit_amount": {
      "type": "number",
      "description": "Deposit amount collected"
    },
    "deposit_paid": {
      "type": "boolean",
      "default": false,
      "description": "Whether the deposit has been paid"
    },
    "deposit_paid_at": {
      "type": "string",
      "description": "ISO datetime when deposit was paid"
    },
    "deposit_payment_method": {
      "type": "string",
      "enum": [
        "card",
        "ach",
        "check"
      ],
      "description": "How the deposit was paid"
    },
    "deposit_transaction_id": {
      "type": "string",
      "description": "Stripe payment intent or transaction ID"
    },
    "portal_access_granted": {
      "type": "boolean",
      "default": false,
      "description": "Whether the customer portal is accessible (granted after deposit)"
    },
    "gps_lat": {
      "type": "number"
    },
    "gps_lng": {
      "type": "number"
    },
    "design_preview_id": {
      "type": "string"
    },
    "google_calendar_event_id": {
      "type": "string"
    },
    "google_drive_folder_id": {
      "type": "string"
    },
    "assigned_to": {
      "type": "string",
      "description": "Email of assigned estimator"
    },
    "walkthrough_date": {
      "type": "string",
      "format": "date"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "internal_notes": {
      "type": "string"
    },
    "approval_token": {
      "type": "string"
    },
    "approval_token_expires": {
      "type": "string"
    },
    "approver_email": {
      "type": "string"
    },
    "approver_notes": {
      "type": "string"
    },
    "approval_sent_at": {
      "type": "string"
    },
    "workflow_stages": {
      "type": "array",
      "description": "Project workflow stages with milestone checklists",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "milestones": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                },
                "done": {
                  "type": "boolean"
                },
                "done_at": {
                  "type": "string"
                },
                "due_date": {
                  "type": "string"
                },
                "custom": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      }
    },
    "workflow_schedule": {
      "type": "object",
      "description": "Project scheduling data",
      "properties": {
        "start_date": {
          "type": "string"
        },
        "estimated_duration_weeks": {
          "type": "number"
        },
        "key_dates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "date": {
                "type": "string"
              },
              "done": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    "documents_meta": {
      "type": "array",
      "description": "Project documents with metadata",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "original_name": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "uploaded_at": {
            "type": "string"
          },
          "size": {
            "type": "number"
          }
        }
      }
    },
    "team_messages": {
      "type": "array",
      "description": "Internal team notes/messages on the project",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "author_email": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          }
        }
      }
    },
    "subcontractor_assignments": {
      "type": "array",
      "description": "Milestones assigned to subcontractors with status tracking",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "milestone_id": {
            "type": "string"
          },
          "subcontractor_email": {
            "type": "string"
          },
          "subcontractor_phone": {
            "type": "string"
          },
          "subcontractor_name": {
            "type": "string"
          },
          "token": {
            "type": "string"
          },
          "token_expires": {
            "type": "string"
          },
          "assigned_at": {
            "type": "string"
          },
          "assigned_by": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "in_progress",
              "complete"
            ]
          },
          "started_at": {
            "type": "string"
          },
          "completed_at": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "quickbooks_customer_id": {
      "type": "string",
      "description": "QuickBooks Customer ID for this project"
    },
    "quickbooks_last_sync": {
      "type": "string",
      "description": "ISO datetime of last QuickBooks sync"
    },
    "quickbooks_sync_status": {
      "type": "string",
      "enum": [
        "not_synced",
        "synced",
        "error",
        "pending"
      ],
      "default": "not_synced",
      "description": "QuickBooks sync status"
    }
  },
  "required": [
    "client_name"
  ]
}