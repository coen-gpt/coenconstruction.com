{
  "name": "AdminUser",
  "type": "object",
  "properties": {
    "email": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "project_manager",
        "assistant_project_manager",
        "site_superintendent",
        "operations_manager",
        "office_admin",
        "field_crew",
        "sales_rep",
        "estimator",
        "viewer"
      ],
      "default": "viewer",
      "description": "User role \u2014 controls access level throughout the system"
    },
    "can_access_estimates": {
      "type": "boolean",
      "default": true
    },
    "can_access_leads": {
      "type": "boolean",
      "default": true
    },
    "can_access_invoices": {
      "type": "boolean",
      "default": false
    },
    "can_access_blog": {
      "type": "boolean",
      "default": false
    },
    "can_access_cms": {
      "type": "boolean",
      "default": false
    },
    "can_access_seo": {
      "type": "boolean",
      "default": false
    },
    "can_access_team": {
      "type": "boolean",
      "default": false
    },
    "can_access_tracking": {
      "type": "boolean",
      "default": false
    },
    "can_access_field_crew": {
      "type": "boolean",
      "default": false,
      "description": "Access to field crew management & reports"
    },
    "can_approve_payroll": {
      "type": "boolean",
      "default": false,
      "description": "Can approve weekly payroll (site superintendent)"
    },
    "active": {
      "type": "boolean",
      "default": true
    },
    "notes": {
      "type": "string"
    },
    "password_hash": {
      "type": "string"
    },
    "reset_token": {
      "type": "string"
    },
    "reset_token_expires": {
      "type": "string"
    }
  },
  "required": [
    "email",
    "name",
    "role"
  ]
}