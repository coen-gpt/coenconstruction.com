{
  "name": "GmailConnection",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string",
      "description": "Team member email"
    },
    "user_name": {
      "type": "string"
    },
    "connector_id": {
      "type": "string",
      "description": "App user connector ID"
    },
    "last_sync": {
      "type": "string",
      "description": "ISO datetime of last sync"
    },
    "sync_status": {
      "type": "string",
      "enum": [
        "idle",
        "syncing",
        "error"
      ],
      "default": "idle"
    },
    "resync_progress": {
      "type": "object",
      "description": "Progress tracking for attachment resync",
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "idle",
            "running",
            "done",
            "error"
          ]
        },
        "current": {
          "type": "integer"
        },
        "total": {
          "type": "integer"
        },
        "started_at": {
          "type": "string"
        },
        "finished_at": {
          "type": "string"
        },
        "updated": {
          "type": "integer"
        },
        "unrecoverable": {
          "type": "integer"
        }
      }
    },
    "total_scanned": {
      "type": "integer",
      "default": 0
    },
    "total_found": {
      "type": "integer",
      "default": 0
    },
    "active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "user_email"
  ]
}