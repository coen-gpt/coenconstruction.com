{
  "name": "ContractorProject",
  "type": "object",
  "properties": {
    "client_name": {
      "type": "string"
    },
    "client_phone": {
      "type": "string"
    },
    "client_email": {
      "type": "string"
    },
    "client_address": {
      "type": "string"
    },
    "client_city": {
      "type": "string"
    },
    "client_zipcode": {
      "type": "string"
    },
    "project_type": {
      "type": "string",
      "enum": [
        "Home Addition",
        "Kitchen Remodel",
        "Bathroom Remodel",
        "Deck / Porch / Pergola",
        "Siding",
        "Custom Carpentry",
        "Snow Removal",
        "Full Home Renovation",
        "Roofing",
        "Flooring",
        "Other"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "walkthrough",
        "draft",
        "sent",
        "pending_review",
        "approved",
        "denied",
        "modify",
        "in_progress",
        "on_hold",
        "completed",
        "cancelled",
        "imported"
      ],
      "default": "walkthrough"
    },
    "description": {
      "type": "string"
    },
    "scope_of_work": {
      "type": "string"
    },
    "rooms": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "dimensions": {
            "type": "string"
          }
        }
      }
    },
    "photos": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "URLs of uploaded site photos"
    },
    "photos_360": {
      "type": "array",
      "description": "360-degree equirectangular photos for virtual site walk with progress markers",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "thumbnail_url": {
            "type": "string"
          },
          "uploaded_at": {
            "type": "string"
          },
          "markers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "pitch": {
                  "type": "number"
                },
                "yaw": {
                  "type": "number"
                },
                "note": {
                  "type": "string"
                },
                "created_at": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "original_estimate_total": {
      "type": "number",
      "default": 0
    },
    "adjusted_total": {
      "type": "number",
      "default": 0
    },
    "client_signed": {
      "type": "boolean",
      "default": false
    },
    "signed_date": {
      "type": "string",
      "format": "date"
    },
    "contract_signed_pdf_url": {
      "type": "string"
    },
    "contract_signature_data": {
      "type": "string"
    },
    "contract_signed_at": {
      "type": "string"
    },
    "deposit_amount": {
      "type": "number"
    },
    "deposit_paid": {
      "type": "boolean",
      "default": false
    },
    "deposit_paid_at": {
      "type": "string"
    },
    "deposit_payment_method": {
      "type": "string",
      "enum": [
        "card",
        "ach",
        "check",
        "quickbooks"
      ]
    },
    "deposit_transaction_id": {
      "type": "string"
    },
    "portal_access_granted": {
      "type": "boolean",
      "default": false
    },
    "gps_lat": {
      "type": "number"
    },
    "gps_lng": {
      "type": "number"
    },
    "design_preview_id": {
      "type": "string"
    },
    "google_calendar_event_id": {
      "type": "string"
    },
    "google_drive_folder_id": {
      "type": "string"
    },
    "assigned_to": {
      "type": "string",
      "description": "Email of assigned estimator"
    },
    "walkthrough_date": {
      "type": "string",
      "format": "date"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "internal_notes": {
      "type": "string"
    },
    "approval_token": {
      "type": "string"
    },
    "approval_token_expires": {
      "type": "string"
    },
    "approver_email": {
      "type": "string"
    },
    "approver_notes": {
      "type": "string"
    },
    "approval_sent_at": {
      "type": "string"
    },
    "material_checklist": {
      "type": "array",
      "description": "Material checklist items tracking ordered and received status",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "quantity": {
            "type": "string"
          },
          "supplier": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          },
          "ordered": {
            "type": "boolean",
            "default": false
          },
          "ordered_at": {
            "type": "string"
          },
          "ordered_by": {
            "type": "string"
          },
          "received": {
            "type": "boolean",
            "default": false
          },
          "received_at": {
            "type": "string"
          },
          "received_by": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          },
          "created_by": {
            "type": "string"
          }
        }
      }
    },
    "workflow_stages": {
      "type": "array",
      "description": "Project workflow stages with milestone checklists",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "milestones": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                },
                "done": {
                  "type": "boolean"
                },
                "done_at": {
                  "type": "string"
                },
                "due_date": {
                  "type": "string"
                },
                "custom": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      }
    },
    "workflow_schedule": {
      "type": "object",
      "description": "Project scheduling data",
      "properties": {
        "start_date": {
          "type": "string"
        },
        "estimated_duration_weeks": {
          "type": "number"
        },
        "key_dates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "date": {
                "type": "string"
              },
              "done": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    "precon_checklist": {
      "type": "object",
      "description": "Pre-construction checklist with materials, subs, and general tasks",
      "properties": {
        "materials": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "subs": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "general": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "documents_meta": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "original_name": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "uploaded_at": {
            "type": "string"
          },
          "size": {
            "type": "number"
          }
        }
      }
    },
    "team_messages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "author_email": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          }
        }
      }
    },
    "subcontractor_assignments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "milestone_id": {
            "type": "string"
          },
          "subcontractor_email": {
            "type": "string"
          },
          "subcontractor_phone": {
            "type": "string"
          },
          "subcontractor_name": {
            "type": "string"
          },
          "token": {
            "type": "string"
          },
          "token_expires": {
            "type": "string"
          },
          "assigned_at": {
            "type": "string"
          },
          "assigned_by": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "in_progress",
              "complete"
            ]
          },
          "started_at": {
            "type": "string"
          },
          "completed_at": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "quickbooks_customer_id": {
      "type": "string"
    },
    "quickbooks_deposit_invoice_id": {
      "type": "string",
      "description": "QuickBooks Invoice Id for the project deposit (online card/ACH payment)"
    },
    "quickbooks_last_sync": {
      "type": "string"
    },
    "quickbooks_sync_status": {
      "type": "string",
      "enum": [
        "not_synced",
        "synced",
        "error",
        "pending"
      ],
      "default": "not_synced"
    }
  },
  "required": [
    "client_name"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "user_condition": {
        "role": "admin"
      }
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}